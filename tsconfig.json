{
  "compilerOptions": {
    "target": "es2020",
    "module": "node16",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "moduleResolution": "node16",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ]
}