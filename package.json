{
  "name": "cppslash",
  "version": "0.1.0",
  "description": "twoslash-like helper for Shiki rendering of C/C++ using clangd",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cppslash": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "lint": "echo \"No linter configured\""
  },
  "keywords": [
    "shiki",
    "clangd",
    "twoslash",
    "c++",
    "c",
    "lsp",
    "syntax-highlighting"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "shiki": "^0.12.0",
    "vscode-jsonrpc": "^9.0.1",
    "vscode-languageserver-protocol": "^3.18.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
